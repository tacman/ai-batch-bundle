<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AI Batch #{{ batch.id }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body class="bg-light">
<div class="container py-4">
    <div class="d-flex gap-2 mb-3">
        <a href="{{ path('tacman_ai_batch_ui_index') }}" class="btn btn-outline-secondary btn-sm">Back to batches</a>
        <a href="/" class="btn btn-outline-secondary btn-sm">App Home</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h1 class="h4 mb-3">Batch #{{ batch.id }}</h1>
            <div class="row g-3">
                <div class="col-md-3"><div class="small text-muted">Task</div><div>{{ batch.task }}</div></div>
                <div class="col-md-2"><div class="small text-muted">Status</div><div><span class="badge text-bg-secondary">{{ batch.status }}</span></div></div>
                <div class="col-md-2"><div class="small text-muted">Provider</div><div>{{ batch.provider }}</div></div>
                <div class="col-md-5"><div class="small text-muted">Provider Batch ID</div><div><code>{{ batch.providerBatchId ?: '-' }}</code></div></div>
                <div class="col-md-3"><div class="small text-muted">Requests</div><div>{{ batch.requestCount }}</div></div>
                <div class="col-md-3"><div class="small text-muted">Completed</div><div>{{ batch.completedCount }}</div></div>
                <div class="col-md-3"><div class="small text-muted">Failed</div><div>{{ batch.failedCount }}</div></div>
                <div class="col-md-3"><div class="small text-muted">Applied</div><div>{{ batch.appliedCount }}</div></div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Custom ID</th>
                        <th>Status</th>
                        <th>Prompt</th>
                        <th>Output</th>
                        <th>Raw</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for result in results %}
                        <tr>
                            <td>{{ result.id }}</td>
                            <td><code>{{ result.customId }}</code></td>
                            <td>
                                {% if result.success %}
                                    <span class="badge text-bg-success">ok</span>
                                {% else %}
                                    <span class="badge text-bg-danger">error</span>
                                {% endif %}
                            </td>
                            <td>{{ result.promptTokens }}</td>
                            <td>{{ result.outputTokens }}</td>
                            <td>
                                <details>
                                    <summary class="small">view</summary>
                                    <andypf-json-viewer
                                        class="d-block border rounded mt-2"
                                        expanded="1"
                                        show-toolbar="true"
                                        data='{{ result.raw|json_encode|e('html_attr') }}'
                                    ></andypf-json-viewer>
                                </details>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="text-muted p-3">No persisted batch results for this batch yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</body>
</html>
