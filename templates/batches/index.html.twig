<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AI Batches</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body class="bg-light">
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">AI Batches</h1>
        <a href="/" class="btn btn-outline-secondary btn-sm">App Home</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Task</th>
                        <th>Status</th>
                        <th>Provider</th>
                        <th>Provider Batch ID</th>
                        <th>Progress</th>
                        <th>Created</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for batch in batches %}
                        <tr>
                            <td><a href="{{ path('tacman_ai_batch_ui_show', {id: batch.id}) }}">#{{ batch.id }}</a></td>
                            <td>{{ batch.task }}</td>
                            <td><span class="badge text-bg-secondary">{{ batch.status }}</span></td>
                            <td>{{ batch.provider }}</td>
                            <td><code>{{ batch.providerBatchId ?: '-' }}</code></td>
                            <td>{{ batch.completedCount }}/{{ batch.requestCount }} (failed: {{ batch.failedCount }})</td>
                            <td>{{ batch.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-muted p-3">No batches persisted yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</body>
</html>
